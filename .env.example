# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_DEBUG=true

# Google OAuth 
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_SCOPES=openid profile email https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/drive.file
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback/google

# Google Sheets API
GOOGLE_SHEETS_PRIVATE_KEY=your-google-sheets-private-key
GOOGLE_SHEETS_CLIENT_EMAIL=your-google-sheets-client-email
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id

# Application Configuration
NODE_ENV=development
